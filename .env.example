# ============================================================================
# OPCALLS - Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control!
# ============================================================================

# ============================================================================
# SUPABASE (Required)
# ============================================================================
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ============================================================================
# APPLICATION (Required)
# ============================================================================
# Your production domain (no trailing slash)
NEXT_PUBLIC_APP_URL=https://opcalls.com

# Secret for cron job authentication (generate with: openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here

# ============================================================================
# STRIPE (Required for billing)
# ============================================================================
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook signing secret - get from Stripe webhook settings
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe products (create products first!)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# ============================================================================
# TWILIO (Required for phone numbers)
# ============================================================================
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# Optional: A verified number for sending SMS notifications
TWILIO_FROM_NUMBER=+1...

# ============================================================================
# RETELL AI (Required for voice agents)
# ============================================================================
# Get these from: https://dashboard.retellai.com
RETELL_API_KEY=...
RETELL_WEBHOOK_SECRET=...

# ============================================================================
# ELEVENLABS (Optional - for voice cloning)
# ============================================================================
# Get these from: https://elevenlabs.io/docs/api-reference
ELEVENLABS_API_KEY=...

# ============================================================================
# EMAIL NOTIFICATIONS (Optional)
# ============================================================================
# Using Resend (recommended) or SendGrid

# Resend
RESEND_API_KEY=re_...

# Or SendGrid
SENDGRID_API_KEY=SG...

# Sender email (must be verified with your provider)
FROM_EMAIL=noreply@opcalls.com

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features
ENABLE_DEMO_CALLS=true
ENABLE_DONE_FOR_YOU=true
ENABLE_BILLING=true

# ============================================================================
# RATE LIMITING
# ============================================================================
# Requests per window (default: 100 requests per 60 seconds)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
# Uncomment for local development
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. Stripe Products Setup:
#    - Create products in Stripe Dashboard
#    - Add price IDs to this file
#    - Update plans table in Supabase with stripe_price_id
#
# 2. Webhooks Setup:
#    - Stripe: Add webhook for /api/webhooks/stripe
#    - Retell: Add webhook for /api/webhooks/retell
#    - Twilio: Add webhook for /api/webhooks/twilio/voice
#
# 3. Cron Jobs Setup (Netlify/Vercel):
#    - /api/cron/grace-periods - Run daily
#    - /api/cron/provisioning-retry - Run every 5 minutes
#
# 4. Admin Setup:
#    After deploying, run this SQL in Supabase:
#    INSERT INTO admin_users (user_id, role, email)
#    VALUES ('your-user-id', 'super_admin', 'you@email.com');
#
